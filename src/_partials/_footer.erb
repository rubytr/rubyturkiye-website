<% i18n_tr = site.data.i18n.tr %>
<% i18n_en = site.data.i18n.en %>

<footer style="background: #111; padding: 36px 32px;">
  <div style="max-width: 1120px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between;">
    <div style="display: flex; align-items: center; gap: 9px;">
      <img src="<%= relative_url '/images/rubytrlogo.svg' %>" alt="Ruby Türkiye" style="height: 28px; width: 28px; flex-shrink: 0; display: block; filter: brightness(0) invert(1);">
      <span style="font-size: 15px; font-weight: 700; letter-spacing: -0.02em; color: #fff;">Ruby Türkiye</span>
    </div>
    <span style="font-size: 13px; color: #555;">
      <span class="tr"><%= i18n_tr.footer %></span><span class="en"><%= i18n_en.footer %></span>
    </span>
    <div style="display: flex; align-items: center; gap: 20px;">
      <a href="<%= site.metadata.twitter_url %>" target="_blank" rel="noopener noreferrer" style="font-size: 13px; color: #555; font-weight: 500; text-decoration: none;">Twitter</a>
      <a href="<%= site.metadata.github_url %>" target="_blank" rel="noopener noreferrer" style="font-size: 13px; color: #555; font-weight: 500; text-decoration: none;">GitHub</a>
      <a href="<%= site.metadata.discord_url %>" target="_blank" rel="noopener noreferrer" style="font-size: 13px; color: #555; font-weight: 500; text-decoration: none;">Discord</a>
    </div>
  </div>
</footer>
