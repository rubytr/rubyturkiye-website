---
layout: default
title: "Ruby Türkiye"
page_id: home
---
<% tr = site.data.i18n.tr %>
<% en = site.data.i18n.en %>

<!-- Hero -->
<section style="padding: 92px 32px 76px; text-align: center;">
  <div style="max-width: 1120px; margin: 0 auto;">
    <div style="display: inline-block; background: #FFF0F0; color: #CC0000; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px 14px; border-radius: 100px; margin-bottom: 28px;">
      <span class="tr"><%= tr.hero.label %></span><span class="en"><%= en.hero.label %></span>
    </div>
    <h1 style="font-size: 56px; font-weight: 800; letter-spacing: -0.045em; line-height: 1.08; color: #111; max-width: 720px; margin: 0 auto 22px;">
      <span class="tr"><%= tr.hero.title %></span><span class="en"><%= en.hero.title %></span>
    </h1>
    <p style="font-size: 18px; line-height: 1.7; color: #666; max-width: 500px; margin: 0 auto 40px;">
      <span class="tr"><%= tr.hero.subtitle %></span><span class="en"><%= en.hero.subtitle %></span>
    </p>
    <div style="display: flex; align-items: center; justify-content: center; gap: 12px;">
      <a href="<%= relative_url '/events' %>" style="display: inline-flex; align-items: center; background: #CC0000; color: #fff; font-size: 14px; font-weight: 600; padding: 13px 28px; border-radius: 7px; letter-spacing: -0.01em; text-decoration: none;">
        <span class="tr"><%= tr.hero.cta1 %></span><span class="en"><%= en.hero.cta1 %></span>
      </a>
      <a href="<%= relative_url '/about' %>" style="display: inline-flex; align-items: center; background: #fff; color: #111; font-size: 14px; font-weight: 600; padding: 12px 28px; border-radius: 7px; border: 1.5px solid #DFDFDF; letter-spacing: -0.01em; text-decoration: none;">
        <span class="tr"><%= tr.hero.cta2 %></span><span class="en"><%= en.hero.cta2 %></span>
      </a>
    </div>
  </div>
</section>

<!-- Stats -->
<section style="background: #FAFAFA; border-top: 1px solid #EBEBEB; border-bottom: 1px solid #EBEBEB; padding: 0 32px;">
  <div style="max-width: 1120px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr);">
    <% tr.stats.each_with_index do |stat_tr, i| %>
      <% stat_en = en.stats[i] %>
      <div style="padding: 40px 32px; text-align: center;<%= i > 0 ? ' border-left: 1px solid #EBEBEB;' : '' %>">
        <div style="font-size: 40px; font-weight: 800; color: #CC0000; letter-spacing: -0.05em; line-height: 1;"><%= stat_tr.value %></div>
        <div style="font-size: 11px; font-weight: 700; color: #AAA; margin-top: 8px; text-transform: uppercase; letter-spacing: 0.08em;">
          <span class="tr"><%= stat_tr.label %></span><span class="en"><%= stat_en.label %></span>
        </div>
      </div>
    <% end %>
  </div>
</section>

<!-- Upcoming Events Preview -->
<section style="padding: 80px 32px; max-width: 1120px; margin: 0 auto;">
  <div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 40px;">
    <div>
      <div style="font-size: 11px; font-weight: 700; color: #CC0000; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;">
        <span class="tr"><%= tr.hero.upcoming_eyebrow %></span><span class="en"><%= en.hero.upcoming_eyebrow %></span>
      </div>
      <h2 style="font-size: 30px; font-weight: 700; letter-spacing: -0.035em; color: #111;">
        <span class="tr"><%= tr.hero.upcoming_title %></span><span class="en"><%= en.hero.upcoming_title %></span>
      </h2>
    </div>
    <a href="<%= relative_url '/events' %>" style="font-size: 13px; font-weight: 600; color: #CC0000; text-decoration: none; display: flex; align-items: center; gap: 5px;">
      <span class="tr"><%= tr.hero.view_all %></span><span class="en"><%= en.hero.view_all %></span> →
    </a>
  </div>

  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
    <% site.data.events.upcoming.first(3).each do |ev| %>
      <div class="card-hover" style="border: 1px solid #E8E8E8; border-radius: 10px; padding: 24px; display: flex; flex-direction: column; gap: 10px; background: #fff;">
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <span style="font-size: 10px; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase; color: #CC0000; background: #FFF0F0; padding: 4px 10px; border-radius: 100px;">
            <span class="tr"><%= ev.type_tr %></span><span class="en"><%= ev.type_en %></span>
          </span>
          <span style="font-size: 12px; color: #AAA; font-weight: 500;">
            <span class="tr"><%= ev.day %> <%= ev.month_tr %> <%= ev.year %></span><span class="en"><%= ev.month_en %> <%= ev.day %>, <%= ev.year %></span>
          </span>
        </div>
        <h3 style="font-size: 17px; font-weight: 700; letter-spacing: -0.02em; color: #111; line-height: 1.35;">
          <span class="tr"><%= ev.title_tr %></span><span class="en"><%= ev.title_en %></span>
        </h3>
        <p style="font-size: 13px; color: #777; line-height: 1.6; flex: 1; margin: 0;">
          <span class="tr"><%= ev.description_tr %></span><span class="en"><%= ev.description_en %></span>
        </p>
        <div style="font-size: 13px; color: #999; font-weight: 500; padding-top: 10px; border-top: 1px solid #F2F2F2;">
          <span class="tr"><%= ev.location_tr %></span><span class="en"><%= ev.location_en %></span>
        </div>
      </div>
    <% end %>
  </div>
</section>

<!-- Community CTA -->
<section style="background: #FAFAFA; border-top: 1px solid #EBEBEB; padding: 80px 32px;">
  <div style="max-width: 600px; margin: 0 auto; text-align: center;">
    <h2 style="font-size: 30px; font-weight: 700; letter-spacing: -0.035em; color: #111; margin-bottom: 14px;">
      <span class="tr"><%= tr.hero.cta_title %></span><span class="en"><%= en.hero.cta_title %></span>
    </h2>
    <p style="font-size: 15px; color: #666; line-height: 1.75; margin-bottom: 36px; margin-top: 0;">
      <span class="tr"><%= tr.hero.cta_subtitle %></span><span class="en"><%= en.hero.cta_subtitle %></span>
    </p>
    <div style="display: flex; align-items: center; justify-content: center; gap: 12px;">
      <a href="<%= site.metadata.discord_url %>" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; background: #CC0000; color: #fff; font-size: 14px; font-weight: 600; padding: 12px 26px; border-radius: 7px; text-decoration: none;">
        <span class="tr"><%= tr.hero.cta_discord %></span><span class="en"><%= en.hero.cta_discord %></span>
      </a>
      <a href="<%= site.metadata.github_url %>" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; background: #fff; color: #111; font-size: 14px; font-weight: 600; padding: 11px 26px; border-radius: 7px; border: 1.5px solid #DFDFDF; text-decoration: none;">
        <span class="tr"><%= tr.hero.cta_github %></span><span class="en"><%= en.hero.cta_github %></span>
      </a>
    </div>
  </div>
</section>
