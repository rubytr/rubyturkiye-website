---
layout: default
title: "Etkinlikler"
page_id: events
---
<% tr = site.data.i18n.tr %>
<% en = site.data.i18n.en %>

<!-- Page Header -->
<section style="padding: 64px 32px 48px; max-width: 1120px; margin: 0 auto; border-bottom: 1px solid #EBEBEB;">
  <div style="font-size: 11px; font-weight: 700; color: #CC0000; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px;">
    <span class="tr"><%= tr.events.eyebrow %></span><span class="en"><%= en.events.eyebrow %></span>
  </div>
  <h1 style="font-size: 40px; font-weight: 800; letter-spacing: -0.04em; color: #111; margin-bottom: 12px;">
    <span class="tr"><%= tr.events.title %></span><span class="en"><%= en.events.title %></span>
  </h1>
  <p style="font-size: 16px; color: #666; line-height: 1.65; max-width: 480px; margin: 0;">
    <span class="tr"><%= tr.events.subtitle %></span><span class="en"><%= en.events.subtitle %></span>
  </p>
</section>

<!-- Upcoming Events -->
<section style="padding: 48px 32px 32px; max-width: 1120px; margin: 0 auto;">
  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 28px;">
    <span style="display: inline-block; width: 7px; height: 7px; background: #CC0000; border-radius: 50%; flex-shrink: 0;"></span>
    <h2 style="font-size: 12px; font-weight: 700; color: #111; letter-spacing: 0.08em; text-transform: uppercase; margin: 0;">
      <span class="tr"><%= tr.events.upcoming_label %></span><span class="en"><%= en.events.upcoming_label %></span>
    </h2>
  </div>
  <% if site.data.events.upcoming.to_a.any? %>
  <div style="display: flex; flex-direction: column; gap: 16px;">
    <% site.data.events.upcoming.to_a.each do |ev| %>
      <div style="display: grid; grid-template-columns: 116px 1fr auto; gap: 28px; align-items: start; padding: 28px; border: 1px solid #E8E8E8; border-radius: 10px; background: #fff;">
        <div style="text-align: center; padding: 14px 12px; background: #FAFAFA; border-radius: 8px; border: 1px solid #EFEFEF;">
          <div style="font-size: 32px; font-weight: 800; color: #CC0000; letter-spacing: -0.05em; line-height: 1;"><%= ev.day %></div>
          <div style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.07em; margin-top: 5px;">
            <span class="tr"><%= ev.month_tr %></span><span class="en"><%= ev.month_en %></span>
          </div>
          <div style="font-size: 11px; color: #CCC; margin-top: 3px;"><%= ev.year %></div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 8px; min-width: 0;">
          <span style="display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase; color: #CC0000; background: #FFF0F0; padding: 3px 10px; border-radius: 100px; width: fit-content;">
            <span class="tr"><%= ev.type_tr %></span><span class="en"><%= ev.type_en %></span>
          </span>
          <h3 style="font-size: 20px; font-weight: 700; letter-spacing: -0.03em; color: #111; line-height: 1.3; margin: 0;">
            <span class="tr"><%= ev.title_tr %></span><span class="en"><%= ev.title_en %></span>
          </h3>
          <p style="font-size: 14px; color: #666; line-height: 1.6; margin: 0;">
            <span class="tr"><%= ev.description_tr %></span><span class="en"><%= ev.description_en %></span>
          </p>
          <div style="display: flex; gap: 24px; margin-top: 2px;">
            <span style="font-size: 13px; color: #888; font-weight: 500;">
              <span class="tr"><%= ev.location_tr %></span><span class="en"><%= ev.location_en %></span>
            </span>
            <span style="font-size: 13px; color: #BBB;">
              <span class="tr"><%= ev.speaker_tr %></span><span class="en"><%= ev.speaker_en %></span>
            </span>
          </div>
        </div>
        <div style="flex-shrink: 0; padding-top: 2px;">
          <a href="<%= ev.register_url || '#' %>" style="display: inline-block; font-size: 13px; font-weight: 600; color: #fff; background: #CC0000; padding: 10px 20px; border-radius: 7px; white-space: nowrap; text-decoration: none;">
            <span class="tr"><%= tr.events.register %></span><span class="en"><%= en.events.register %></span>
          </a>
        </div>
      </div>
    <% end %>
  </div>
  <% else %>
  <div style="padding: 64px 32px; text-align: center; background: #FAFAFA; border: 1px solid #EBEBEB; border-radius: 12px;">
    <div style="width: 44px; height: 44px; background: #FFF0F0; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 18px; font-size: 20px;">📅</div>
    <p style="font-size: 16px; font-weight: 600; color: #333; margin-bottom: 8px;">
      <span class="tr">Şu an planlanmış etkinlik yok</span><span class="en">No upcoming events right now</span>
    </p>
    <p style="font-size: 14px; color: #999; line-height: 1.6; max-width: 340px; margin: 0 auto 24px;">
      <span class="tr">Yeni etkinlik duyuruları için Slack kanalımıza katılın veya Twitter'ı takip edin.</span><span class="en">Join our Slack or follow us on Twitter to hear about new events as they're announced.</span>
    </p>
    <div style="display: flex; align-items: center; justify-content: center; gap: 12px;">
      <a href="<%= site.metadata.slack_url %>" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; font-size: 13px; font-weight: 600; color: #fff; background: #CC0000; padding: 10px 20px; border-radius: 7px; text-decoration: none;">
        <span class="tr">Slack'e Katıl</span><span class="en">Join Slack</span>
      </a>
      <a href="<%= site.metadata.x_url %>" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; font-size: 13px; font-weight: 600; color: #555; background: #fff; padding: 9px 20px; border-radius: 7px; border: 1.5px solid #DFDFDF; text-decoration: none;">
        X
      </a>
    </div>
  </div>
  <% end %>
</section>

<!-- Past Events -->
<section style="padding: 24px 32px 80px; max-width: 1120px; margin: 0 auto;">
  <div style="display: flex; align-items: center; gap: 10px; padding: 20px 0; border-top: 1px solid #EBEBEB;">
    <h2 style="font-size: 12px; font-weight: 700; color: #111; letter-spacing: 0.08em; text-transform: uppercase; margin: 0;">
      <span class="tr"><%= tr.events.past_label %></span><span class="en"><%= en.events.past_label %></span>
    </h2>
  </div>
  <% site.data.events.past.each do |ev| %>
    <div style="display: grid; grid-template-columns: 120px 1fr 140px; gap: 24px; align-items: center; padding: 14px 0; border-bottom: 1px solid #F4F4F4;">
      <span style="font-size: 13px; color: #BBB; font-weight: 400;">
        <span class="tr"><%= ev.date_tr %></span><span class="en"><%= ev.date_en %></span>
      </span>
      <div style="display: flex; align-items: center; gap: 12px; min-width: 0; overflow: hidden;">
        <span style="display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #BBB; background: #F5F5F5; padding: 2px 8px; border-radius: 100px; white-space: nowrap; flex-shrink: 0;">
          <span class="tr"><%= ev.type_tr %></span><span class="en"><%= ev.type_en %></span>
        </span>
        <% urls = ev.youtube_urls.to_a %>
        <% if urls.length == 1 %>
          <a href="<%= urls.first %>" target="_blank" rel="noopener noreferrer" style="font-size: 15px; font-weight: 600; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-decoration: none;">
            <span class="tr"><%= ev.title_tr %></span><span class="en"><%= ev.title_en %></span>
          </a>
        <% elsif urls.length > 1 %>
          <span style="font-size: 15px; font-weight: 600; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            <span class="tr"><%= ev.title_tr %></span><span class="en"><%= ev.title_en %></span>
          </span>
          <% urls.each_with_index do |url, i| %>
            <a href="<%= url %>" target="_blank" rel="noopener noreferrer" style="font-size: 11px; font-weight: 600; color: #CC0000; text-decoration: none; flex-shrink: 0;">▶ <%= i + 1 %></a>
          <% end %>
        <% else %>
          <span style="font-size: 15px; font-weight: 600; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            <span class="tr"><%= ev.title_tr %></span><span class="en"><%= ev.title_en %></span>
          </span>
        <% end %>
      </div>
      <span style="font-size: 13px; color: #BBB; text-align: right; white-space: nowrap;">
        <span class="tr"><%= ev.location_tr %></span><span class="en"><%= ev.location_en %></span>
      </span>
    </div>
  <% end %>
</section>
