<% i18n_tr = site.data.i18n.tr %>
<% i18n_en = site.data.i18n.en %>

<footer style="background: #111; padding: 32px 16px;">
  <div class="footer-inner">
    <div style="display: flex; align-items: center; gap: 9px;">
      <img src="<%= relative_url '/images/rubytrlogo.svg' %>" alt="Ruby Türkiye" style="height: 28px; width: 28px; flex-shrink: 0; display: block; filter: brightness(0) invert(1);">
      <span style="font-size: 15px; font-weight: 700; letter-spacing: -0.02em; color: #fff;">Ruby Türkiye</span>
    </div>
    <span class="footer-copyright" style="font-size: 13px; color: #555;">
      <span class="tr"><%= i18n_tr.footer %></span><span class="en"><%= i18n_en.footer %></span>
    </span>
    <div class="footer-links">
      <a href="<%= site.metadata.x_url %>" target="_blank" rel="noopener noreferrer" style="font-size: 13px; color: #555; font-weight: 500; text-decoration: none;">X</a>
      <a href="<%= site.metadata.kommunity_url %>" target="_blank" rel="noopener noreferrer" style="font-size: 13px; color: #555; font-weight: 500; text-decoration: none;">Kommunity</a>
      <a href="<%= site.metadata.github_url %>" target="_blank" rel="noopener noreferrer" style="font-size: 13px; color: #555; font-weight: 500; text-decoration: none;">GitHub</a>
      <a href="<%= site.metadata.slack_url %>" target="_blank" rel="noopener noreferrer" style="font-size: 13px; color: #555; font-weight: 500; text-decoration: none;">Slack</a>
    </div>
  </div>
</footer>
